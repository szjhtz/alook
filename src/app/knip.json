{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": [
    "scripts/**/*.{ts,mjs}"
  ],
  "project": ["src/**/*.ts"],
  "ignoreDependencies": [
    "citty",
    "playwright-core",
    "postal-mime",
    "bun-types"
  ],
  "ignoreBinaries": [
    "predev",
    "printf",
    "pbcopy",
    "xclip",
    "taskkill"
  ],
  "vitest": {
    "entry": ["test/**/*.test.ts"]
  },
  "eslint": {
    "entry": ["eslint.config.mjs"]
  }
}
